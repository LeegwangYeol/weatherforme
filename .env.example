# ===========================================================================
# WeatherForMe 환경변수 템플릿 — 복사해서 .env.local 로 저장하세요
# 배포시에는 Vercel 프로젝트 환경변수에 동일하게 등록해야 합니다.
# ===========================================================================

# 웹 푸시 VAPID 키 — `npx web-push generate-vapid-keys` 로 생성
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 푸시 서비스에 전달되는 연락처 (mailto: 형식)
VAPID_SUBJECT=mailto:you@example.com

# 기상청 단기예보 조회서비스 API 키 — 아래 둘 중 하나만 설정하면 됩니다
# 1) 공공데이터포털(https://www.data.go.kr): "기상청_단기예보 ((구)_동네예보) 조회서비스"
#    활용신청 후 일반 인증키(Decoding) → KMA_SERVICE_KEY
#    (발급/신청 직후엔 게이트웨이 반영까지 최대 1시간 걸릴 수 있음)
# 2) 기상청 API허브(https://apihub.kma.go.kr): 발급받은 인증키 → KMA_APIHUB_KEY
KMA_SERVICE_KEY=
KMA_APIHUB_KEY=

# /api/cron/weather 보호용 시크릿 — `openssl rand -base64 24` 등으로 생성
# GitHub Actions 시크릿(CRON_SECRET)과 Vercel 환경변수에 동일한 값 등록
CRON_SECRET=

# Upstash Redis (구독자 저장소)
# Vercel 대시보드 → Storage → Upstash for Redis 연결시 자동 주입됨
# 로컬에서 실제 저장소를 쓰려면 Upstash 콘솔에서 복사
KV_REST_API_URL=
KV_REST_API_TOKEN=

# (선택) 비 감지 리드타임: 향후 N시간 내 강수 예보시 알림 (기본 2)
# RAIN_LOOKAHEAD_HOURS=2
# (선택) 같은 사용자 재알림 쿨다운 시간 (기본 3)
# NOTIFY_COOLDOWN_HOURS=3
